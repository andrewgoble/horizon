{% comment %}
  Section for rendering cart upsells via Section Rendering API.
  Returns compact cart-upsells-product-card snippets for injection by cart-upsells.js.
{% endcomment %}

{% if recommendations.performed and recommendations.products_count > 0 %}
  {% for product in recommendations.products limit: 9 %}
    {% render 'cart-upsells-product-card', product: product %}
  {% endfor %}
{% endif %}
